@page
@model PersonalFinanceTracker.Pages.Transactions.IndexModel

@{
    ViewData["Title"] = "Transactions";
}

<h1>Transactions</h1>

<p>
    <a asp-page="CreateTransactions" class="btn btn-primary">Add Transaction</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Date</th>
            <th>Description</th>
            <th>Type</th>
            <th>Category</th>
            <th>Amount</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Transactions)
{
        <tr>
            <td>@item.Date.ToShortDateString()</td>
            <td>@item.Description</td>
            <td>@item.Type</td>
            <td>@(item.Category?.Name ?? "-")</td>
            <td>@item.Amount.ToString("C")</td>
            <td>
                <a asp-page="UpdateTransactions" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="DetailsTransactions" asp-route-id="@item.Id">Details</a> |
                <a asp-page="DeleteTransactions" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
