@page "{id}"
@model PersonalFinanceTracker.Pages.Users.DetailsUserModel

@{
    ViewData["Title"] = "User Details";
}

<h1>User Details</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Full Name</dt>
        <dd class="col-sm-9">@Model.User.FullName</dd>

        <dt class="col-sm-3">Email</dt>
        <dd class="col-sm-9">@Model.User.Email</dd>
    </dl>
</div>
<div>
    <a asp-page="UpdateUser" asp-route-id="@Model.User.Id" class="btn btn-primary">Edit</a>
    <a asp-page="Index" class="btn btn-secondary">Back to list</a>
</div>
