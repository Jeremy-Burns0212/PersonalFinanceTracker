@page
@model PersonalFinanceTracker.Pages.Users.IndexModel

@{
    ViewData["Title"] = "Users";
}

<h1>Users</h1>

<p>
    <a asp-page="CreateUser" class="btn btn-primary">Add User</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Full Name</th>
            <th>Email</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Users)
{
        <tr>
            <td>@item.FullName</td>
            <td>@item.Email</td>
            <td>
                <a asp-page="UpdateUser" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="DetailsUser" asp-route-id="@item.Id">Details</a> |
                <a asp-page="DeleteUser" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
